# ─────────────────────────────────────────────────────────────────────────────
# Scriba — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── SEGURANÇA — NUNCA versionar ───────────────────────────────────────────────
.env
*.env
.env.local
.env.*.local

# Banco de dados (dados reais da biblioteca)
*.db
*.db-shm
*.db-wal
*.sqlite

# Backups locais
scriba/
backups/

# ── Maven ─────────────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── IDEs ──────────────────────────────────────────────────────────────────────

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ── Sistema Operacional ───────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
spring.log

# ── Outros ───────────────────────────────────────────────────────────────────
*.class
*.jar
!mvnw
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar