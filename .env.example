# ─────────────────────────────────────────────────────────────────────────────
# Scriba — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores no arquivo .env
#   3. NUNCA versione o .env — ele já está no .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────

# Nome da biblioteca exibido na interface
SCRIBA_NOME=Biblioteca Espírita

# Porta do servidor (padrão: 8080)
SCRIBA_PORT=8080

# ── Banco de Dados ────────────────────────────────────────────────────────────

# Caminho do arquivo SQLite (padrão: pasta home do usuário)
# Exemplo Linux/macOS: /home/usuario/scriba/biblioteca.db
# Exemplo Windows:     C:/Users/usuario/scriba/biblioteca.db
SCRIBA_DB_PATH=

# ── Segurança ─────────────────────────────────────────────────────────────────

# Senha do administrador inicial (gerada no primeiro boot se vazia)
# Mínimo: 12 caracteres, pelo menos 1 número e 1 caractere especial
SCRIBA_ADMIN_PASSWORD=

# Chave secreta para assinatura de sessão (mínimo 32 caracteres aleatórios)
# Gere com: openssl rand -base64 32
SCRIBA_SESSION_SECRET=

# ── Notificações por E-mail ───────────────────────────────────────────────────

# Habilitar notificações por e-mail (true/false)
MAIL_ENABLED=false

# Servidor SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Credenciais SMTP
# Para Gmail: use uma App Password (não a senha da conta)
# Veja: https://myaccount.google.com/apppasswords
MAIL_USER=
MAIL_APP_PASSWORD=

# E-mail remetente exibido nas mensagens
MAIL_FROM=Biblioteca Espírita <biblioteca@exemplo.com.br>

# ── WhatsApp (v1.1 — opcional) ────────────────────────────────────────────────

# URL da instância Evolution API
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# ─────────────────────────────────────────────────────────────────────────────
# Dúvidas? Abra uma issue: https://github.com/LuizLourenco/Scriba/issues
# ─────────────────────────────────────────────────────────────────────────────
